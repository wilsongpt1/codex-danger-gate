{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoLogo -NoProfile -NonInteractive -File \"$PLUGIN_ROOT/scripts/safety-context.ps1\"",
            "commandWindows": "powershell.exe -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File \"%PLUGIN_ROOT%\\scripts\\safety-context.ps1\"",
            "timeout": 10,
            "statusMessage": "Loading destructive-action confirmation policy"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoLogo -NoProfile -NonInteractive -File \"$PLUGIN_ROOT/scripts/safety-context.ps1\"",
            "commandWindows": "powershell.exe -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File \"%PLUGIN_ROOT%\\scripts\\safety-context.ps1\"",
            "timeout": 10,
            "statusMessage": "Loading destructive-action confirmation policy"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Bash|apply_patch|Edit|Write|mcp__.*)$",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoLogo -NoProfile -NonInteractive -File \"$PLUGIN_ROOT/scripts/danger-gate.ps1\"",
            "commandWindows": "powershell.exe -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File \"%PLUGIN_ROOT%\\scripts\\danger-gate.ps1\"",
            "timeout": 120,
            "statusMessage": "Waiting for manual confirmation of a high-risk action"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoLogo -NoProfile -NonInteractive -File \"$PLUGIN_ROOT/scripts/danger-gate.ps1\"",
            "commandWindows": "powershell.exe -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File \"%PLUGIN_ROOT%\\scripts\\danger-gate.ps1\"",
            "timeout": 120,
            "statusMessage": "Waiting for manual confirmation of a sandbox permission request"
          }
        ]
      }
    ]
  }
}
